ttps://nvd.nist.gov/vuln/detail/CVE-2025-64702"],"description":"quic-go HTTP/3 QPACK Header Expansion DoS","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-64702","epss":0.00061,"percentile":0.19047,"date":"2026-03-05"}],"cwes":[{"cve":"CVE-2025-64702","cwe":"CWE-770","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["0.57.0"],"state":"fixed","available":[{"version":"0.57.0","date":"2025-12-12","kind":"first-observed"}]},"advisories":[],"risk":0.031415},"relatedVulnerabilities":[{"id":"CVE-2025-64702","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2025-64702","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/quic-go/quic-go/commit/5b2d2129f8315da41e01eff0a847ab38a34e83a8","https://github.com/quic-go/quic-go/security/advisories/GHSA-g754-hx8w-x2g6"],"description":"quic-go is an implementation of the QUIC protocol in Go. Versions 0.56.0 and below are vulnerable to excessive memory allocation through quic-go's HTTP/3 client and server implementations by sending a QPACK-encoded HEADERS frame that decodes into a large header field section (many unique header names and/or large values). The implementation builds an http.Header (used on the http.Request and http.Response, respectively), while only enforcing limits on the size of the (QPACK-compressed) HEADERS frame, but not on the decoded header, leading to memory exhaustion. This issue is fixed in version 0.57.0.","cvss":[{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:N/A:L","metrics":{"baseScore":5.3,"exploitabilityScore":3.9,"impactScore":1.5},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-64702","epss":0.00061,"percentile":0.19047,"date":"2026-03-05"}],"cwes":[{"cve":"CVE-2025-64702","cwe":"CWE-770","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"go-module-matcher","searchedBy":{"language":"go","namespace":"github:language:go","package":{"name":"github.com/quic-go/quic-go","version":"v0.49.1"}},"found":{"vulnerabilityID":"GHSA-g754-hx8w-x2g6","versionConstraint":"<0.57.0 (go)"},"fix":{"suggestedVersion":"0.57.0"}}],"artifact":{"id":"pkg:golang/github.com/quic-go/quic-go@v0.49.1?package-id=27bf7c289ce82672","name":"github.com/quic-go/quic-go","version":"v0.49.1","type":"go-module","locations":[{"path":"/go.mod","accessPath":""}],"language":"go","licenses":[],"cpes":["cpe:2.3:a:quic-go:quic-go:v0.49.1:*:*:*:*:*:*:*","cpe:2.3:a:quic-go:quic_go:v0.49.1:*:*:*:*:*:*:*","cpe:2.3:a:quic_go:quic-go:v0.49.1:*:*:*:*:*:*:*","cpe:2.3:a:quic_go:quic_go:v0.49.1:*:*:*:*:*:*:*","cpe:2.3:a:quic:quic-go:v0.49.1:*:*:*:*:*:*:*","cpe:2.3:a:quic:quic_go:v0.49.1:*:*:*:*:*:*:*"],"purl":"pkg:golang/github.com/quic-go/quic-go@v0.49.1","upstreams":[],"metadataType":"GolangModMetadata","metadata":{"h1Digest":"h1:e5JXpUyF0f2uFjckQzD8jTghZrOUK1xxDqqZhlwixo0="}}},{"vulnerability":{"id":"GHSA-qxp5-gwg8-xv66","dataSource":"https://github.com/advisories/GHSA-qxp5-gwg8-xv66","namespace":"github:language:go","severity":"Medium","urls":["https://nvd.nist.gov/vuln/detail/CVE-2025-22870","https://go.dev/cl/654697","https://go.dev/issue/71984","https://pkg.go.dev/vuln/GO-2025-3503","http://www.openwall.com/lists/oss-security/2025/03/07/2","https://security.netapp.com/advisory/ntap-20250509-0007"],"description":"HTTP Proxy bypass using IPv6 Zone IDs in golang.org/x/net","cvss":[{"type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:L/AC:L/PR:L/UI:N/S:U/C:L/I:N/A:L","metrics":{"baseScore":4.4,"exploitabilityScore":1.9,"impactScore":2.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-22870","epss":0.00024,"percentile":0.06163,"date":"2026-03-05"}],"cwes":[{"cve":"CVE-2025-22870","cwe":"CWE-115","source":"134c704f-9b21-4f2e-91b3-4a467353bcc0","type":"Se