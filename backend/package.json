{
  "name": "@x0tta/api-gateway",
  "version": "1.0.0",
  "description": "x0tta6bl4 Mesh API Gateway — Nest.js",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "test": "jest",
    "test:cov": "jest --coverage --coverageReporters=cobertura --coverageReporters=text",
    "test:integration": "jest --config jest.integration.json",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@willsoto/nestjs-prometheus": "^6.0.0",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis-yet": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "keyv": "^5.6.0",
    "prom-client": "^15.1.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": "__tests__/.*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "reporters": ["default", "jest-junit"],
    "coverageReporters": ["text", "cobertura"]
  }
}
