# Telegram Bot Configuration
# Token obtained from @BotFather
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghij
# Comma-separated list of admin Telegram user IDs
ADMIN_IDS=12345678,87654321
# Connection string for the bot database
DATABASE_URL=sqlite+aiosqlite:///bot.db

# X-UI Panel Configuration
# Full URL to the X-UI panel
XUI_PANEL_URL=http://127.0.0.1:54321
# X-UI admin username
XUI_USERNAME=admin
# X-UI admin password
XUI_PASSWORD=admin

# Xray Configuration
# Path to the Xray config JSON file
XRAY_CONFIG_PATH=/etc/xray/config.json

# Subscription Service
# Base URL for the client subscription links
SUBSCRIPTION_BASE_URL=https://sub.example.com/

# Node Hosts
# IP address or domain for the Netherlands node
NL_HOST=89.125.1.107
# IP address or domain for the St. Petersburg node
SPB_HOST=192.168.1.100
