{
  "name": "x0tta6bl4-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "mobile:sync": "npm run build && cap sync",
    "android:sync": "npm run build && cap sync android",
    "android:build": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:release:unsigned": "npm run android:sync && cd android && ./gradlew assembleRelease",
    "android:release:signed": "npm run android:sync && cd android && ./gradlew requireReleaseSigning assembleRelease bundleRelease",
    "ios:sync": "npm run build && cap sync ios",
    "desktop:dev": "cd .. && tauri dev",
    "desktop:build": "cd .. && tauri build",
    "desktop:build:linux": "cd .. && tauri build --bundles deb appimage",
    "desktop:build:windows": "cd .. && tauri build --bundles msi",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/ios": "^7.6.5",
    "@tauri-apps/api": "^2.11.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "express-http-proxy": "^2.1.2",
    "pg": "^8.19.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.5",
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.0-beta.13"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
