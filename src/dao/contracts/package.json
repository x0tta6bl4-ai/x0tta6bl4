{
  "name": "x0tta6bl4-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for x0tta6bl4 mesh network (X0T Token, Governance)",
  "type": "module",
  "scripts": {
    "check:qos-mirror": "bash scripts/check_qos_mirror_sync.sh",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:qos": "hardhat test test/QoSManager.test.js",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy_x0t.js --network localhost",
    "deploy:mumbai": "hardhat run scripts/deploy_x0t.js --network polygon_mumbai",
    "deploy:polygon": "hardhat run scripts/deploy_x0t.js --network polygon",
    "deploy:base-testnet": "hardhat run scripts/deploy_x0t.js --network base_sepolia",
    "deploy:base": "hardhat run scripts/deploy_x0t.js --network base",
    "deploy:bridge:local": "hardhat run scripts/deploy_bridge.js --network localhost",
    "deploy:bridge:base-testnet": "hardhat run scripts/deploy_bridge.js --network base_sepolia",
    "node": "hardhat node"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.2.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.13",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.6",
    "@nomicfoundation/hardhat-mocha": "^3.0.17",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "chai": "^5.1.2",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "hardhat": "^3.8.0",
    "mocha": "^11.1.0"
  },
  "overrides": {
    "brace-expansion": "^2.0.3",
    "diff": "^8.0.3",
    "follow-redirects": "^1.16.0",
    "lodash": "^4.18.1",
    "picomatch": "^2.3.2",
    "uuid": "^14.0.0",
    "serialize-javascript": "^7.0.5",
    "undici": "^6.24.0",
    "tmp": "^0.2.4",
    "cookie": "^0.7.0"
  },
  "keywords": [
    "ethereum",
    "solidity",
    "erc20",
    "token",
    "mesh",
    "x0tta6bl4"
  ],
  "author": "x0tta6bl4 Team",
  "license": "MIT",
  "engines": {
    "node": ">=22.10.0"
  }
