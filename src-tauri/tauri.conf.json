{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "x0tta6bl4",
  "version": "0.1.0",
  "identifier": "net.x0tta6bl4.mesh",
  "build": {
    "beforeDevCommand": "npm --prefix x0tta6bl4-app run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm --prefix x0tta6bl4-app run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../x0tta6bl4-app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "x0tta6bl4",
        "width": 1180,
        "height": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https://tauri.localhost; connect-src 'self' http://127.0.0.1:8000 http://127.0.0.1:8001 http://127.0.0.1:8081 http://localhost:8000 http://localhost:8001 http://localhost:8081; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "linux": {
      "deb": {
        "postInstallScript": "debian/postinst",
        "postRemoveScript": "debian/postrm",
        "preRemoveScript": "debian/prerm",
        "files": {
          "/usr/lib/x0tta6bl4/desktop_core_api.py": "runtime/desktop_core_api.py",
          "/usr/lib/x0tta6bl4/desktop_mesh_runtime.py": "runtime/desktop_mesh_runtime.py",
          "/usr/lib/x0tta6bl4/start_full_core_api.sh": "runtime/start_full_core_api.sh",
          "/usr/lib/systemd/system/x0tta6bl4-core-api.service": "systemd/x0tta6bl4-core-api.service",
          "/usr/lib/systemd/system/x0tta6bl4-full-core-api.service": "systemd/x0tta6bl4-full-core-api.service",
          "/usr/lib/systemd/system/x0tta6bl4-node.service": "systemd/x0tta6bl4-node.service"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
