{
  "uid": "x0tta-pqc-performance",
  "title": "PQC Handshake Performance",
  "description": "Kyber KEM handshake latency (p50/p95/p99), failure rates, session reuse",
  "tags": ["x0tta", "pqc", "kyber", "security"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "algorithm",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(pqc_handshake_duration_seconds_bucket, algorithm)",
        "current": { "value": "kyber768" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Handshake p50",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(pqc_handshake_duration_seconds_bucket{algorithm=\"$algorithm\"}[5m])) * 1000",
          "legendFormat": "p50 ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 2,
      "title": "Handshake p95",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(pqc_handshake_duration_seconds_bucket{algorithm=\"$algorithm\"}[5m])) * 1000"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 20, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Handshake p99",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(pqc_handshake_duration_seconds_bucket{algorithm=\"$algorithm\"}[5m])) * 1000"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 30, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Failure Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(pqc_handshake_failures_total{algorithm=\"$algorithm\"}[5m]) / rate(pqc_handshake_total{algorithm=\"$algorithm\"}[5m]) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Session Reuse Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(pqc_session_reused_total[5m]) / rate(pqc_handshake_total[5m]) * 100"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 50, "color": "yellow" },
              { "value": 80, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Handshake Latency Over Time (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(pqc_handshake_duration_seconds_bucket{algorithm=\"$algorithm\"}[2m])) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(pqc_handshake_duration_seconds_bucket{algorithm=\"$algorithm\"}[2m])) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(pqc_handshake_duration_seconds_bucket{algorithm=\"$algorithm\"}[2m])) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 7,
      "title": "Handshake Throughput (handshakes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(pqc_handshake_total{algorithm=\"$algorithm\"}[1m])",
          "legendFormat": "{{algorithm}} handshakes/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "title": "Failures by Error Type",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (error_type) (rate(pqc_handshake_failures_total[5m]))",
          "legendFormat": "{{error_type}}"
        }
      ]
    }
  ]
}
