{
  "uid": "x0tta-sla-metrics",
  "title": "SLA Metrics",
  "description": "Uptime (95% target), MTTR (< 2.5s), throughput (10 Mbps)",
  "tags": ["x0tta", "sla", "mesh"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Mesh Uptime (24h) — Target: 95%",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg(mesh_node_uptime_percent) * 100",
          "legendFormat": "Uptime %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 90, "color": "yellow" },
              { "value": 95, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["last"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 2,
      "title": "MTTR p95 — Target: < 2.5s",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(mesh_heal_duration_seconds_bucket[1h])) * 1000",
          "legendFormat": "MTTR p95 ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 2500, "color": "yellow" },
              { "value": 5000, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Network Throughput — Target: 10 Mbps",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(mesh_bytes_forwarded_total[5m])) * 8 / 1e6",
          "legendFormat": "Throughput Mbps"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Mbps",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 5, "color": "yellow" },
              { "value": 10, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Error Rate — Target: < 0.5%",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{app=\"mesh-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{app=\"mesh-api\"}[5m])) * 100",
          "legendFormat": "Error rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Uptime % — 7-day rolling",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg_over_time(avg(mesh_node_uptime_percent)[7d:1h]) * 100",
          "legendFormat": "Uptime (7d avg)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 80, "max": 100 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Uptime (7d avg)" },
            "properties": [
              { "id": "custom.lineWidth", "value": 2 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [{ "value": 95, "color": "green" }]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "MTTR Distribution",
      "type": "histogram",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (le) (rate(mesh_heal_duration_seconds_bucket[1h]))",
          "legendFormat": "{{le}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "API Request Latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket{app=\"mesh-api\"}[5m]))) * 1000",
          "legendFormat": "p99 — {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket{app=\"mesh-api\"}[5m]))) * 1000",
          "legendFormat": "p95 — {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket{app=\"mesh-api\"}[5m]))) * 1000",
          "legendFormat": "p50 — {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "p99.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4] } }
            ]
          }
        ]
      }
    }
  ]
}
