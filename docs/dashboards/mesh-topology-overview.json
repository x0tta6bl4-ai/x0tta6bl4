{
  "uid": "x0tta-mesh-topology",
  "title": "Mesh Topology Overview",
  "description": "Force-directed topology, node counts, edge counts, and per-region breakdown",
  "tags": ["x0tta", "mesh", "topology"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(mesh_nodes_total, namespace)",
        "current": { "value": "x0tta-production" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Mesh Nodes",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(mesh_nodes_total{namespace=\"$namespace\"})",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 3, "color": "yellow" },
              { "value": 10, "color": "green" }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Active Nodes",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(mesh_nodes_total{namespace=\"$namespace\", status=\"active\"})",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "green", "mode": "fixed" } }
      }
    },
    {
      "id": 3,
      "title": "Degraded / Down Nodes",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(mesh_nodes_total{namespace=\"$namespace\", status=~\"degraded|down\"})",
          "legendFormat": "Degraded+Down"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Mesh Edges (peer connections)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(mesh_edges_total{namespace=\"$namespace\"})",
          "legendFormat": "Edges"
        }
      ]
    },
    {
      "id": 5,
      "title": "Node Registration Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(mesh_nodes_registered_total{namespace=\"$namespace\"}[5m]) * 60",
          "legendFormat": "{{region}} — registrations/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 6,
      "title": "Nodes by Status Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (status) (mesh_nodes_total{namespace=\"$namespace\"})",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "active" }, "properties": [{ "id": "color", "value": { "fixedColor": "#22c55e", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "degraded" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "down" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 7,
      "title": "Topology API Latency (p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(mesh_topology_fetch_duration_seconds_bucket{namespace=\"$namespace\"}[5m])) * 1000",
          "legendFormat": "p99 latency ms"
        },
        {
          "expr": "histogram_quantile(0.50, rate(mesh_topology_fetch_duration_seconds_bucket{namespace=\"$namespace\"}[5m])) * 1000",
          "legendFormat": "p50 latency ms"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99 latency ms" },
            "properties": [{ "id": "thresholds", "value": { "steps": [{ "value": 100, "color": "red" }] } }]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Nodes by Region",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (region) (mesh_nodes_total{namespace=\"$namespace\", status=\"active\"})",
          "legendFormat": "{{region}}"
        }
      ]
    }
  ]
}
